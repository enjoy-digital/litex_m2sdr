    defaults = lab["defaults"]
    lines = [
        "# LiteX-M2SDR RF Lab",
        "",
        f"- Title: {lab['title']}",
        f"- Created: {lab['created_at']}",
        f"- Description: {lab['description'] or 'n/a'}",
        "",
        "## Defaults",
        "",
        f"- Device: {defaults.get('device') or 'n/a'}",
        f"- Sample rate: {defaults.get('sample_rate') or 'n/a'}",
        f"- Center frequency: {defaults.get('center_freq') or 'n/a'}",
        f"- Format: {defaults.get('format') or 'n/a'}",
        f"- Channels: {defaults.get('nchannels') or 'n/a'}",
        "",
        "## Workflow",
        "",
        "```bash",
        f"./m2sdr_lab capture {shlex.quote(str(root))} --samples 2000000 --name baseline",
        f"./m2sdr_lab replay  {shlex.quote(str(root))} baseline",
        f"./m2sdr_lab compare {shlex.quote(str(root))} baseline baseline",
        f"./m2sdr_lab bundle  {shlex.quote(str(root))}",
