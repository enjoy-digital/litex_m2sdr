import json
import re
import shlex
import shutil
import subprocess
import tarfile
from pathlib import Path


LAB_SCHEMA_VERSION = 1
LAB_MANIFEST_NAME = "lab.json"


def utc_now():
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def sanitize_name(value):
    value = re.sub(r"[^A-Za-z0-9._-]+", "-", value.strip().lower()).strip("-")
    return value or "run"


def sha256_file(path):
    digest = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def relative_to_root(root, path):
    try:
        return str(path.relative_to(root))
    except ValueError:
        return str(path)


def read_json(path):
    with path.open("r", encoding="utf-8") as f:
        return json.load(f)


def write_json(path, data):
    with path.open("w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, sort_keys=True)
        f.write("\n")


def write_text(path, text):
    path.write_text(text, encoding="utf-8")


def ensure_lab_dirs(root):
    for dirname in ("captures", "replays", "reports", "bundles"):
        (root / dirname).mkdir(parents=True, exist_ok=True)


def load_lab(root):
    manifest = root / LAB_MANIFEST_NAME
    if not manifest.exists():
        raise SystemExit(f"Missing {LAB_MANIFEST_NAME} in {root}")
    lab = read_json(manifest)
    if lab.get("schema_version") != LAB_SCHEMA_VERSION:
        raise SystemExit(
            f"Unsupported lab schema version: {lab.get('schema_version')} "
            f"(expected {LAB_SCHEMA_VERSION})"
        )
    ensure_lab_dirs(root)
    return lab


def save_lab(root, lab):
    write_json(root / LAB_MANIFEST_NAME, lab)


