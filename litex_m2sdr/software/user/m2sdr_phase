#!/usr/bin/env python3

# SPDX-License-Identifier: BSD-2-Clause

import argparse
import json

from m2sdr_analysis import phase_compare, write_json


def main():
    parser = argparse.ArgumentParser(description="Measure channel-to-channel phase and gain deltas from a SigMF capture.")
    parser.add_argument("sigmf")
    parser.add_argument("--reference", type=int, default=0)
    parser.add_argument("--candidate", type=int, default=1)
    parser.add_argument("--max-samples", type=int, default=None)
    parser.add_argument("--output", default="")
    args = parser.parse_args()

    report = {
        "tool": "m2sdr_phase",
        "result": phase_compare(
            args.sigmf,
            reference=args.reference,
            candidate=args.candidate,
            max_samples=args.max_samples,
        ),
    }
    if args.output:
        write_json(args.output, report)
    print(json.dumps(report, indent=2, sort_keys=True))


if __name__ == "__main__":
    main()
