#!/usr/bin/env python3

# SPDX-License-Identifier: BSD-2-Clause

import argparse
import json

from m2sdr_analysis import timecheck_summary, write_json


def main():
    parser = argparse.ArgumentParser(description="Inspect capture timing metadata and continuity from a SigMF capture.")
    parser.add_argument("sigmf")
    parser.add_argument("--output", default="")
    args = parser.parse_args()

    report = {
        "tool": "m2sdr_timecheck",
        "result": timecheck_summary(args.sigmf),
    }
    if args.output:
        write_json(args.output, report)
    print(json.dumps(report, indent=2, sort_keys=True))


if __name__ == "__main__":
    main()
